[user]
  name = lemuel-manske
  email = lemuelkauemanskede.liz@philips.com
[pager]
  branch = false
[diff]
	colorMoved = zebra
[branch]
	sort = -committerdate
[pull]
	rebase = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential "https://github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/usr/bin/gh auth git-credential
